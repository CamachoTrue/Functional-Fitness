# Variables para servir las Edge Functions en LOCAL:
#   supabase functions serve --env-file supabase/functions/.env.local
# Copia este archivo a supabase/functions/.env.local (gitignored) y rellena.
# NUNCA se versionan valores reales. En el proyecto desplegado, SUPABASE_URL,
# SUPABASE_ANON_KEY y SUPABASE_SERVICE_ROLE_KEY los inyecta Supabase solo; los
# secretos de Mercado Pago se cargan con `supabase secrets set`.

# Supabase local (ver `supabase status`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Mercado Pago (credenciales de PRUEBA para sandbox; formato TEST-...)
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxx
MERCADO_PAGO_WEBHOOK_SECRET=xxxxxxxx

# URL pública del frontend (para back_urls y auto_return de la preferencia).
# En local, para pruebas de punta a punta con MP puede requerir un túnel público.
APP_URL=http://localhost:5173
