# Public browser configuration. Copy to .env.local and provide real values.
VITE_APP_URL=http://localhost:5173
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Número de WhatsApp para el botón flotante de contacto. Valor PÚBLICO (se
# incluye en el bundle del navegador). Formato: código de país + número, solo
# dígitos, sin '+', espacios ni guiones. Ejemplo México: 5215555555555.
# Si se deja vacío o sin definir, el botón simplemente no se muestra.
VITE_WHATSAPP_NUMBER=5215555555555

# Mercado Pago credentials and SUPABASE_SERVICE_ROLE_KEY belong in Supabase
# Edge Function secrets. Never add them to a VITE_* variable or this file.
#
# Edge Function secrets (server-side only). NEVER use the VITE_ prefix for these:
# doing so would ship them in the browser bundle. In production set them with
# `supabase secrets set NAME=value`; for local `supabase functions serve` copy the
# names below into supabase/functions/.env.local (gitignored).
#
#   SUPABASE_URL=http://127.0.0.1:54321
#   SUPABASE_ANON_KEY=your-local-anon-key
#   SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
#   MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxx
#   MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret
#   APP_URL=http://localhost:5173
